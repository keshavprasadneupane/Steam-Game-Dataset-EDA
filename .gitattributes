# ----------------------------------------------------------------------
# 1. Line Endings (Cross-Platform Normalization)
# ----------------------------------------------------------------------
# Set default behavior to automatically normalize line endings to LF on commit
* text=auto

# Explicitly declare text files that must keep native line endings
*.py text
*.json text
*.md text
*.csv text
*.txt text

# Explicitly declare binary files (should never be modified by line-ending conversions)
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary

# ----------------------------------------------------------------------
# 2. Git LFS (Large File Storage) for Data and Models
# ----------------------------------------------------------------------
# Automatically track large data files and machine learning weights
# (Uncomment these if you use Git LFS in your workspace)
# *.csv filter=lfs diff=lfs merge=lfs -text
# *.parquet filter=lfs diff=lfs merge=lfs -text
# *.pkl filter=lfs diff=lfs merge=lfs -text
# *.h5 filter=lfs diff=lfs merge=lfs -text

# ----------------------------------------------------------------------
# 3. Jupyter Notebook Customization
# ----------------------------------------------------------------------
# Treat notebook files as text, but lean on specialized git tools if available
*.ipynb text

# Optional: If you use 'nbstripout' or 'jupytext' to clean notebooks before committing
# *.ipynb filter=nbstripout

# ----------------------------------------------------------------------
# 4. GitHub/GitLab Linguistic & UI Overrides
# ----------------------------------------------------------------------
# Prevent auto-generated lockfiles, visual plots, or data folders from ruining repository stats
data/** linguist-vendored
plots/** linguist-vendored
*.png linguist-generated
*.jpg linguist-generated

# If you use 'uv' or 'poetry' for package management, treat lockfiles as binary-ish for diffs
uv.lock linguist-generated
poetry.lock linguist-generated